# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE (PostgreSQL — Free options: Neon, Supabase, Railway) ────────────
# Neon:     https://neon.tech       (free 512MB)
# Supabase: https://supabase.com    (free 500MB)
# Railway:  https://railway.app     (free $5 credit/mo)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fastprinting?sslmode=require"

# ─── GOOGLE OAUTH 2.0 ─────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Application type: Android
# 4. Package name: com.xfastgroup.fastprinting
# 5. SHA-1 fingerprint: get via  keytool -list -v -keystore ~/.android/debug.keystore
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=use_a_very_long_random_string_here_minimum_64_chars
JWT_EXPIRE=30d

# ─── EMAIL (Gmail SMTP + App Password) ───────────────────────────────────────
# Enable 2FA → Google Account → Security → App Passwords → Mail → Generate
EMAIL_USER=fastmediaagencyofficial@gmail.com
EMAIL_PASS=rlyr jiuf oipr rabz

# ─── CLOUDINARY (free 25GB) — https://cloudinary.com/users/register/free ─────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── PAYMENT ACCOUNTS (served from backend only) ─────────────────────────────
JAZZCASH_NUMBER=0325-2467463
EASYPAISA_NUMBER=0321-0846667
PAYMENT_ACCOUNT_NAME=XFast Group

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── ADMIN PANEL CREDENTIALS ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@xfastgroup.com
ADMIN_PASSWORD=Admin@12345
